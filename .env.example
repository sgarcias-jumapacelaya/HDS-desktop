VITE_API_BASE=https://hds.jumapa.in/api
VITE_KEYCLOAK_URL=https://kclk.jumapa.in
VITE_KEYCLOAK_REALM=hds
VITE_KEYCLOAK_CLIENT_ID=hds-desktop
VITE_POLL_INTERVAL_MS=30000

# Focus mode (toast grouping)
VITE_FOCUS_WINDOW_MS=8000
VITE_FOCUS_GROUP_THRESHOLD=2
# Quiet hours: rango "HH-HH" (ej. 22-7). Vacío = desactivado.
VITE_QUIET_HOURS=

# Time tracker idle auto-pause (ms). 0 desactiva.
VITE_IDLE_AUTO_PAUSE_MS=300000
