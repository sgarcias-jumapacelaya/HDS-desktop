{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HDS Desktop",
  "version": "0.1.0",
  "identifier": "in.jumapa.hds.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HDS Desktop",
        "width": 380,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "HDS Desktop"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Cliente de bandeja para HDS",
    "longDescription": "Notificaciones, time tracking y cambio rápido de estados de tickets HDS."
  },
  "plugins": {
    "autostart": {
      "args": ["--minimized"]
    }
  }
}
